# newapi-monitor 配置示例
# 复制为 .env 并填写真实值;.env 已被 .gitignore 忽略,切勿提交真实凭证。

# —— 必填 ——
# new-api 库的【只读】DSN(MySQL)。建议用只读账号,仅授予 logs/channels 表 SELECT。
NEWAPI_LOG_DSN=ro_user:pass@tcp(db-host:3306)/newapi?charset=utf8mb4&timeout=5s&readTimeout=10s
# new-api 地址,用于登录鉴权(调用其 /api/user/login)
MONITOR_NEWAPI_BASE_URL=https://your-newapi.example.com
# 会话签名密钥:openssl rand -hex 32
MONITOR_SESSION_SECRET=

# —— 可选(含默认值)——
MONITOR_ADDR=:8090
MONITOR_STORE_PATH=/data/monitor.db
MONITOR_SAMPLE_SECONDS=60
MONITOR_RETENTION_DAYS=7
MONITOR_BACKFILL_HOURS=24
